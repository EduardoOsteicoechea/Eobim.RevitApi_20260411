    <Copy
      SourceFiles="$(MSBuildThisFileDirectory)AddInManifest\Eobim.RevitApi.addin"
      DestinationFolder="$(RevitAddins2027Root)"
      SkipUnchangedFiles="true" />
  </Target>-->

</Project>
